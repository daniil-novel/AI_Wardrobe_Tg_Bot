APP_ENV=local
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://api:8000
MINIAPP_PUBLIC_URL=https://your-tunnel.example
API_HOST_PORT=8000
MINIAPP_HOST_PORT=5173
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

POSTGRES_DB=ai_wardrobe
POSTGRES_USER=ai_wardrobe
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://ai_wardrobe:change-me@postgres:5432/ai_wardrobe
SYNC_DATABASE_URL=postgresql+psycopg://ai_wardrobe:change-me@postgres:5432/ai_wardrobe
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_IMAGE=google/gemini-pro-latest
OPENROUTER_MODEL_TEXT=google/gemini-pro-latest
AI_DAILY_BUDGET_USD=20

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=ai-wardrobe-private
S3_REGION=us-east-1
SIGNED_URL_TTL_SECONDS=900

FREE_ITEMS_LIMIT=20
FREE_AI_ANALYSES_PER_MONTH=5
PREMIUM_ITEMS_LIMIT=500
PREMIUM_AI_ANALYSES_PER_MONTH=100

TELEGRAM_PAYMENT_PROVIDER_TOKEN=
EXTERNAL_PAYMENT_PROVIDER_URL=
